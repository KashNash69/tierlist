# Discord OAuth2 Application credentials
# Create your app at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
ADMIN_DISCORD_IDS=

# This MUST match exactly what you set in the Discord app's "Redirects" list
DISCORD_REDIRECT_URI=
NEXT_PUBLIC_API_URL=
# Frontend URL (for redirects after login/logout)
FRONTEND_URL=

# API port (optional, defaults to 3000)
PORT=
